---
const { lang, t } = Astro.props;
---

<section class="py-16 md:py-24 bg-primary-900 text-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center" data-aos="fade-up">
    <h2 class="text-3xl md:text-4xl font-bold mb-4">{t("cta.title")}</h2>
    <p class="text-lg text-neutral-200 mb-8 max-w-2xl mx-auto">{t("cta.subtitle")}</p>
    <a
      href="/contact"
      class="inline-flex items-center gap-2 bg-accent-500 hover:bg-accent-600 text-white px-8 py-3.5 rounded-xl font-semibold text-lg transition-all hover:shadow-lg hover:-translate-y-0.5"
    >
      {t("cta.button")}
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={lang === "ar" ? "M15 19l-7-7 7-7" : "M9 5l7 7-7 7"} />
      </svg>
    </a>
  </div>
</section>

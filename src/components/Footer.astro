---
import { useTranslations, useTranslatedPath } from "../i18n/utils";

const { lang, dir } = Astro.props;
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<footer class="bg-neutral-900 text-neutral-300 mt-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <div class="flex items-center gap-2 text-white font-bold text-lg mb-4">
          <svg class="w-6 h-6 text-secondary-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2L2 7l10 5 10-5-10-5z" />
            <path d="M2 17l10 5 10-5" />
            <path d="M2 12l10 5 10-5" />
          </svg>
          <span>Besma<span class="text-secondary-500">Info</span>Energy</span>
        </div>
        <p class="text-sm text-neutral-400">
          {t("hero.subtitle")}
        </p>
      </div>
      <div>
        <h3 class="text-white font-semibold mb-4">{t("nav.services")}</h3>
        <ul class="space-y-2 text-sm">
          <li><a href={translatePath("services")} class="hover:text-secondary-500 transition-colors">{t("services.it.title")}</a></li>
          <li><a href={translatePath("services")} class="hover:text-secondary-500 transition-colors">{t("services.energy.title")}</a></li>
          <li><a href={translatePath("portfolio")} class="hover:text-secondary-500 transition-colors">{t("nav.portfolio")}</a></li>
          <li><a href={translatePath("blog")} class="hover:text-secondary-500 transition-colors">{t("nav.blog")}</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-white font-semibold mb-4">{t("contact.info.title")}</h3>
        <ul class="space-y-2 text-sm">
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-secondary-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            <span>besmainfoenergy@gmail.com</span>
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-secondary-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            <span dir="ltr">+213 (0) 663 62 20 10<br/>+213 (0) 559 32 82 04</span>
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-secondary-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            <span>{t("contact.info.full_location")}</span>
          </li>
        </ul>
      </div>
    </div>
    <div class="border-t border-neutral-800 mt-8 pt-8 flex flex-col md:flex-row items-center justify-between gap-4 text-sm">
      <p>&copy; {new Date().getFullYear()} BesmaInfoEnergy — {t("footer.rights")}</p>
      <div class="flex gap-4">
        <a href={translatePath("legal")} class="hover:text-secondary-500 transition-colors">{t("footer.legal")}</a>
        <a href={translatePath("privacy")} class="hover:text-secondary-500 transition-colors">{t("footer.privacy")}</a>
      </div>
    </div>
  </div>
</footer>

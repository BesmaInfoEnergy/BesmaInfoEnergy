---
const { lang, title, subtitle, ctaText, ctaLink, bannerSrc } = Astro.props;
---

<section class="relative overflow-hidden bg-gradient-to-br from-primary-900 via-primary-700 to-primary-600 text-white">
  {bannerSrc && (
    <div class="absolute inset-0">
      <img src={bannerSrc} alt="" aria-hidden="true" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-br from-primary-900/85 via-primary-700/75 to-primary-600/65"></div>
    </div>
  )}
  <div class="absolute inset-0 opacity-10">
    <svg class="w-full h-full" viewBox="0 0 800 800" xmlns="http://www.w3.org/2000/svg">
      <defs><pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse"><path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="1" /></pattern></defs>
      <rect width="100%" height="100%" fill="url(#grid)" />
    </svg>
  </div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-36 relative">
    <div class="max-w-3xl" data-aos="fade-up">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight mb-6">
        {title}
      </h1>
      <p class="text-lg md:text-xl text-neutral-100 mb-10 leading-relaxed">
        {subtitle}
      </p>
      <div class="flex flex-wrap gap-4">
        {ctaLink && ctaText && (
          <a href={ctaLink} class="inline-flex items-center gap-2 bg-secondary-500 hover:bg-secondary-600 text-white px-8 py-3.5 rounded-xl font-semibold text-lg transition-all hover:shadow-lg hover:-translate-y-0.5">
            {ctaText}
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={lang === "ar" ? "M15 19l-7-7 7-7" : "M9 5l7 7-7 7"} /></svg>
          </a>
        )}
      </div>
    </div>
  </div>
  <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-neutral-50 to-transparent"></div>
</section>

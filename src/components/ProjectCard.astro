---
const { project, lang, t } = Astro.props;
const content = project[lang] || project.fr;
---

<article class="bg-white rounded-2xl border border-neutral-200 overflow-hidden hover:shadow-lg transition-all group" data-aos="fade-up">
  <div class="aspect-video bg-gradient-to-br from-primary-100 to-secondary-100 flex items-center justify-center overflow-hidden">
    {project.image ? (
      <img src={project.image} alt={content.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
    ) : (
      <svg class="w-16 h-16 text-primary-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
    )}
  </div>
  <div class="p-6">
    <div class="flex items-center gap-2 mb-3">
      <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${project.category === "it" ? "bg-primary-50 text-primary-700" : "bg-secondary-50 text-secondary-700"}`}>
        {project.category === "it" ? "Informatique" : "Énergie"}
      </span>
    </div>
    <h3 class="text-xl font-semibold text-neutral-900 mb-2">{content.title}</h3>
    <p class="text-neutral-600 text-sm mb-4">{content.description}</p>
    <div class="flex flex-wrap gap-2 mb-4">
      {project.tags?.map((tag) => (
        <span class="text-xs bg-neutral-100 text-neutral-600 px-2 py-1 rounded">{tag}</span>
      ))}
    </div>
    <p class="text-xs text-neutral-500 mb-4">
      <span class="font-medium">{t("portfolio.tech")} :</span> {content.tech}
    </p>
    {project.link && (
      <a href={project.link} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-sm font-medium text-primary-600 hover:text-primary-700">
        {t("portfolio.view")}
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
      </a>
    )}
  </div>
</article>

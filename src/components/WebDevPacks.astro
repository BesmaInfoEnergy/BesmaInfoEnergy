---
const { lang, t, contactUrl = "/contact" } = Astro.props;

const packs = [
  {
    id: "vitrine",
    icon: "globe",
    gradient: "from-blue-500 to-blue-600",
    badge: "Nouveau",
  },
  {
    id: "ecommerce",
    icon: "zap",
    gradient: "from-emerald-500 to-emerald-600",
    badge: "Populaire",
  },
  {
    id: "custom",
    icon: "code",
    gradient: "from-violet-500 to-violet-600",
    badge: null,
  },
];

const icons = {
  globe: '<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9" /></svg>',
  zap: '<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>',
  code: '<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" /></svg>',
};
---
<div class="mt-8" data-aos="fade-up">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    {packs.map((pack) => {
      const img = `/images/packs/${pack.id}.svg`;
      return (
        <article class="group relative bg-white rounded-2xl border border-neutral-200 p-6 hover:shadow-xl hover:border-transparent hover:-translate-y-1 transition-all duration-300">
          <div class="absolute inset-0 rounded-2xl bg-gradient-to-b from-neutral-50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none" />
          <div class="relative z-10">
            <div class={`w-14 h-14 bg-gradient-to-br ${pack.gradient} rounded-xl flex items-center justify-center text-white shadow-lg mb-4`}>
              <span set:html={icons[pack.icon]} />
            </div>
            {pack.badge && (
              <span class={`inline-block text-xs font-bold px-2.5 py-1 rounded-full mb-3 ${pack.id === "ecommerce" ? "bg-emerald-50 text-emerald-700" : "bg-blue-50 text-blue-700"}`}>
                {pack.badge}
              </span>
            )}
            <h4 class="text-lg font-bold text-neutral-900 mb-2">{t(`services.packs.${pack.id}.title`)}</h4>
            <p class="text-sm text-neutral-600 leading-relaxed mb-4">{t(`services.packs.${pack.id}.desc`)}</p>
            <div class="text-xs text-neutral-500 font-medium leading-relaxed border-t border-neutral-100 pt-4 mt-4">
              {t(`services.packs.${pack.id}.features`)}
            </div>
            <a
              href={contactUrl}
              class={`mt-5 w-full inline-flex items-center justify-center gap-2 text-sm font-semibold px-4 py-2.5 rounded-xl text-white bg-gradient-to-r ${pack.gradient} hover:opacity-90 transition-opacity`}
            >
              {t("services.cta")}
            </a>
          </div>
        </article>
      );
    })}
  </div>
</div>

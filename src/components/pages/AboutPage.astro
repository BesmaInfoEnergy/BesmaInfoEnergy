---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const itSkillKeys = ["about.skills.it.1", "about.skills.it.2", "about.skills.it.3", "about.skills.it.4", "about.skills.it.5", "about.skills.it.6", "about.skills.it.7"];
const energySkillKeys = ["about.skills.energy.1", "about.skills.energy.2", "about.skills.energy.3", "about.skills.energy.4", "about.skills.energy.5", "about.skills.energy.6", "about.skills.energy.7", "about.skills.energy.8"];
const expKeys = ["about.experience.1", "about.experience.2", "about.experience.3", "about.experience.4", "about.experience.5", "about.experience.6"];
const bgKeys = ["about.background.1", "about.background.2", "about.background.3"];
---

<BaseLayout
  title={t("about.title")}
  description={t("about.subtitle")}
  lang={lang}
  dir={lang === "ar" ? "rtl" : "ltr"}
>
  <section class="py-20 md:py-28">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16" data-aos="fade-up">
        <h1 class="text-4xl md:text-5xl font-bold text-neutral-900 mb-4">{t("about.title")}</h1>
        <p class="text-xl text-neutral-600">{t("about.subtitle")}</p>
      </div>

      <div class="flex flex-col md:flex-row gap-12 items-center mb-20" data-aos="fade-up">
        <div class="shrink-0 w-48 h-48 rounded-full bg-gradient-to-br from-primary-100 to-secondary-100 flex items-center justify-center text-6xl font-bold text-primary-600">B</div>
        <div>
          <h2 class="text-2xl font-semibold text-neutral-900 mb-4">BesmaInfoEnergy</h2>
          <p class="text-neutral-600 leading-relaxed text-lg">{t("about.bio")}</p>
        </div>
      </div>

      <div class="mb-16" data-aos="fade-up">
        <h2 class="text-2xl font-bold text-neutral-900 mb-6">{t("about.mission")}</h2>
        <div class="bg-primary-50 border border-primary-100 rounded-2xl p-8">
          <p class="text-neutral-700 text-lg leading-relaxed">{t("about.mission.text")}</p>
        </div>
      </div>

      <div class="mb-16" data-aos="fade-up">
        <h2 class="text-2xl font-bold text-neutral-900 mb-8">{t("about.skills")}</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="bg-white border border-neutral-200 rounded-2xl p-6">
            <h3 class="font-semibold text-primary-700 mb-4 flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              {t("services.it.title")}
            </h3>
            <ul class="space-y-2 text-neutral-600">
              {itSkillKeys.map((key) => (
                <li class="flex items-start gap-2"><span class="text-secondary-500 mt-1">&#8226;</span>{t(key)}</li>
              ))}
            </ul>
          </div>
          <div class="bg-white border border-neutral-200 rounded-2xl p-6">
            <h3 class="font-semibold text-secondary-700 mb-4 flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
              {t("services.energy.title")}
            </h3>
            <ul class="space-y-2 text-neutral-600">
              {energySkillKeys.map((key) => (
                <li class="flex items-start gap-2"><span class="text-secondary-500 mt-1">&#8226;</span>{t(key)}</li>
              ))}
            </ul>
          </div>
        </div>
      </div>

      <div data-aos="fade-up">
        <h2 class="text-2xl font-bold text-neutral-900 mb-6">{t("about.certifications")}</h2>

        <h3 class="text-lg font-semibold text-primary-700 mb-4 flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          {t("about.experience.title")}
        </h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-10">
          {expKeys.map((key) => (
            <div class="flex items-center gap-3 bg-white border border-neutral-200 rounded-xl p-4">
              <div class="w-2 h-2 rounded-full bg-secondary-500 shrink-0"></div>
              <span class="text-neutral-700">{t(key)}</span>
            </div>
          ))}
        </div>

        <h3 class="text-lg font-semibold text-secondary-700 mb-4 flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" /></svg>
          {t("about.background.title")}
        </h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {bgKeys.map((key) => (
            <div class="flex items-center gap-3 bg-white border border-neutral-200 rounded-xl p-4">
              <div class="w-2 h-2 rounded-full bg-primary-500 shrink-0"></div>
              <span class="text-neutral-700">{t(key)}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="mt-16" data-aos="fade-up">
        <h2 class="text-2xl font-bold text-neutral-900 mb-6">{t("about.links")}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <a href="https://www.anae.dz/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-4 bg-white border border-neutral-200 rounded-xl p-5 hover:border-primary-300 hover:shadow-md transition-all">
            <div class="w-14 h-14 rounded-xl bg-white flex items-center justify-center shrink-0 overflow-hidden p-2">
              <img src="/images/anae-logo.png" alt="ANAE" class="w-full h-full object-contain" />
            </div>
            <div>
              <p class="font-medium text-neutral-900">ANAE</p>
              <p class="text-sm text-neutral-500">{t("about.links.anae")}</p>
            </div>
          </a>
          <a href="https://moukawil.dz/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-4 bg-white border border-neutral-200 rounded-xl p-5 hover:border-primary-300 hover:shadow-md transition-all">
            <div class="w-14 h-14 rounded-xl bg-white flex items-center justify-center shrink-0 overflow-hidden p-2">
              <img src="/images/moukawil-logo.png" alt="Moukawil" class="w-full h-full object-contain" />
            </div>
            <div>
              <p class="font-medium text-neutral-900">Moukawil</p>
              <p class="text-sm text-neutral-500">{t("about.links.moukawil")}</p>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

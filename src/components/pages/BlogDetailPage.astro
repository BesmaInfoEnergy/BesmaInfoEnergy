---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getLangFromUrl, useTranslations, useTranslatedPath } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const { post } = Astro.props;
const data = post.data;
---

<BaseLayout
  title={data.title}
  description={data.description}
  lang={lang}
  dir={lang === "ar" ? "rtl" : "ltr"}
>
  <section class="py-20 md:py-28">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href={translatePath("blog")} class="inline-flex items-center gap-2 text-primary-600 hover:text-primary-700 font-medium mb-8">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={lang === "ar" ? "M9 5l7 7-7 7" : "M15 19l-7-7 7-7"} /></svg>
        {t("blog.back")}
      </a>

      <article data-aos="fade-up">
        <div class="flex flex-wrap gap-2 mb-4">
          {data.tags?.map((tag) => (
            <span class="text-xs bg-neutral-100 text-neutral-600 px-2.5 py-1 rounded-full">{tag}</span>
          ))}
        </div>
        <h1 class="text-3xl md:text-4xl font-bold text-neutral-900 mb-4">{data.title}</h1>
        <p class="text-lg text-neutral-600 mb-6">{data.description}</p>
        <time class="text-sm text-neutral-500 block mb-8">
          {data.pubDate.toLocaleDateString(lang === "ar" ? "ar-DZ" : lang === "en" ? "en-US" : "fr-FR")}
        </time>

        {data.image && (
          <img src={data.image} alt={data.title} class="w-full rounded-2xl mb-8" loading="lazy" />
        )}

        <div class="prose prose-neutral max-w-none">
          <slot />
        </div>
      </article>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FAQItem from "../FAQItem.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const faqData = [
  { key: "solaire", fr: { q: "Quels sont les avantages de l'énergie solaire en Algérie ?", r: "L'Algérie bénéficie d'un ensoleillement parmi les meilleurs au monde. L'énergie solaire permet de réduire votre facture d'électricité de 50 à 80%, de bénéficier de l'autoconsommation et de contribuer à la transition énergétique." }, en: { q: "What are the benefits of solar energy in Algeria?", r: "Algeria has one of the best sunshine rates in the world. Solar energy can reduce your electricity bill by 50-80%, allow self-consumption, and contribute to the energy transition." }, ar: { q: "ما هي مزايا الطاقة الشمسية في الجزائر؟", r: "تتمتع الجزائر بأحد أفضل معدلات الإشعاع الشمسي في العالم. تسمح الطاقة الشمسية بتخفيض فاتورة الكهرباء بنسبة 50-80٪ والاستهلاك الذاتي والمساهمة في التحول الطاقوي." } },
  { key: "devis", fr: { q: "Comment obtenir un devis ?", r: "Vous pouvez me contacter via le formulaire de contact, par email ou par téléphone. Je vous répondrai sous 24h avec un devis gratuit et personnalisé après avoir analysé vos besoins." }, en: { q: "How to get a quote?", r: "You can contact me via the contact form, by email or by phone. I will respond within 24h with a free personalized quote after analyzing your needs." }, ar: { q: "كيف يمكنني الحصول على عرض سعر؟", r: "يمكنك الاتصال بي عبر نموذج الاتصال أو البريد الإلكتروني أو الهاتف. سأرد خلال 24 ساعة بعرض سعر مجاني ومخصص بعد تحليل احتياجاتك." } },
  { key: "delais", fr: { q: "Quels sont les délais pour un projet web ?", r: "Un site vitrine simple peut être livré en 1 à 2 semaines. Une application plus complexe peut prendre de 4 à 8 semaines selon les fonctionnalités." }, en: { q: "What are the timelines for a web project?", r: "A simple showcase site can be delivered in 1-2 weeks. A more complex application can take 4-8 weeks depending on features." }, ar: { q: "ما هي المهل الزمنية لمشروع ويب؟", r: "يمكن تسليم موقع تعريفي بسيط في 1-2 أسبوعين. التطبيق الأكثر تعقيداً قد يستغرق 4-8 أسابيع حسب الميزات." } },
  { key: "maintenance", fr: { q: "Proposez-vous un contrat de maintenance ?", r: "Oui, je propose des contrats de maintenance mensuels ou annuels pour vos équipements informatiques et vos installations solaires, incluant le suivi et les interventions préventives." }, en: { q: "Do you offer a maintenance contract?", r: "Yes, I offer monthly or annual maintenance contracts for your computer equipment and solar installations, including monitoring and preventive interventions." }, ar: { q: "هل تقدم عقود صيانة؟", r: "نعم، أقدم عقود صيانة شهرية أو سنوية لمعداتك الحاسوبية ومنشآتك الشمسية، تشمل المتابعة والتدخلات الوقائية." } },
  { key: "secteurs", fr: { q: "Dans quelles régions d'Algérie intervenez-vous ?", r: "J'interviens principalement à Alger et ses environs, mais je peux me déplacer dans tout le pays pour des projets d'envergure." }, en: { q: "In which regions of Algeria do you operate?", r: "I operate mainly in Algiers and its surroundings, but I can travel throughout the country for larger projects." }, ar: { q: "في أي مناطق الجزائر تتدخل؟", r: "أتدخل بشكل أساسي في الجزائر العاصمة وضواحيها، لكن يمكنني التنقل في جميع أنحاء البلاد للمشاريع الكبيرة." } },
  { key: "certification", fr: { q: "Êtes-vous certifié pour les installations solaires ?", r: "Oui, je possède les certifications nécessaires pour l'installation et la maintenance de systèmes photovoltaïques et de chauffe-eau solaires, conformément aux normes algériennes et internationales." }, en: { q: "Are you certified for solar installations?", r: "Yes, I have the necessary certifications for the installation and maintenance of photovoltaic systems and solar water heaters, in accordance with Algerian and international standards." }, ar: { q: "هل أنت معتمد لتركيبات الطاقة الشمسية؟", r: "نعم، لدي الشهادات اللازمة لتركيب وصيانة الأنظمة الكهروضوئية وسخانات المياه الشمسية، وفقاً للمعايير الجزائرية والدولية." } },
];
const items = faqData.map((item) => item[lang] || item.fr);
---

<BaseLayout
  title={t("faq.title")}
  description={t("faq.subtitle")}
  lang={lang}
  dir={lang === "ar" ? "rtl" : "ltr"}
>
  <section class="py-20 md:py-28 bg-gradient-to-b from-primary-900 to-primary-700 text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center" data-aos="fade-up">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">{t("faq.title")}</h1>
      <p class="text-xl text-neutral-200">{t("faq.subtitle")}</p>
    </div>
  </section>

  <section class="py-20 md:py-28">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-4">
        {items.map((item, i) => (
          <FAQItem key={i} question={item.q} answer={item.r} lang={lang} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

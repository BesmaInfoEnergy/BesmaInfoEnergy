---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HeroSection from "../HeroSection.astro";
import CTASection from "../CTASection.astro";
import ServiceCard from "../ServiceCard.astro";
import ProjectCard from "../ProjectCard.astro";
import TestimonialCard from "../TestimonialCard.astro";
import { getLangFromUrl, useTranslations, useTranslatedPath } from "../../i18n/utils";
import services from "../../data/services.json";
import projects from "../../data/projects.json";
import testimonials from "../../data/testimonials.json";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<BaseLayout
  title="Accueil"
  description="Expert en informatique et énergie en Algérie. Développement web, maintenance, solaire photovoltaïque, audits énergétiques."
  lang={lang}
  dir={lang === "ar" ? "rtl" : "ltr"}
>
  <HeroSection
    lang={lang}
    title={t("hero.title")}
    subtitle={t("hero.subtitle")}
    ctaText={t("hero.cta.services")}
    ctaLink={translatePath("services")}
  />

  <section class="py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16" data-aos="fade-up">
        <h2 class="text-3xl md:text-4xl font-bold text-neutral-900 mb-4">{t("section.services.title")}</h2>
        <p class="text-lg text-neutral-600 max-w-2xl mx-auto">{t("section.services.subtitle")}</p>
      </div>
      <div class="mb-12">
        <h3 class="text-2xl font-bold text-primary-700 mb-6 flex items-center gap-3">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          {t("section.services.it")}
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {services.filter((s) => s.category === "it").map((service) => (
            <ServiceCard key={service.id} service={service} lang={lang} t={t} contactUrl={translatePath("contact")} />
          ))}
        </div>
      </div>
      <div>
        <h3 class="text-2xl font-bold text-secondary-700 mb-6 flex items-center gap-3">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
          {t("section.services.energy")}
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {services.filter((s) => s.category === "energy").map((service) => (
            <ServiceCard key={service.id} service={service} lang={lang} t={t} contactUrl={translatePath("contact")} />
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16" data-aos="fade-up">
        <h2 class="text-3xl md:text-4xl font-bold text-neutral-900 mb-4">{t("section.portfolio.title")}</h2>
        <p class="text-lg text-neutral-600">{t("section.portfolio.subtitle")}</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {projects.slice(0, 4).map((project) => (
          <ProjectCard key={project.id} project={project} lang={lang} t={t} />
        ))}
      </div>
      <div class="text-center mt-12" data-aos="fade-up">
        <a href={translatePath("portfolio")} class="inline-flex items-center gap-2 text-primary-600 hover:text-primary-700 font-semibold">
          {t("section.portfolio.view")}
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={lang === "ar" ? "M15 19l-7-7 7-7" : "M9 5l7 7-7 7"} /></svg>
        </a>
      </div>
    </div>
  </section>

  <section class="py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16" data-aos="fade-up">
        <h2 class="text-3xl md:text-4xl font-bold text-neutral-900 mb-4">{t("section.testimonials.title")}</h2>
        <p class="text-lg text-neutral-600">{t("section.testimonials.subtitle")}</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {testimonials.map((t) => (
          <TestimonialCard key={t.id} testimonial={t} lang={lang} />
        ))}
      </div>
    </div>
  </section>

  <CTASection lang={lang} t={t} />
</BaseLayout>

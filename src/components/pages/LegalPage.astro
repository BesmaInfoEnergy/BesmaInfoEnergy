---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout
  title={t("legal.title")}
  description={t("legal.desc")}
  lang={lang}
  dir={lang === "ar" ? "rtl" : "ltr"}
>
  <section class="py-20 md:py-28">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-bold text-neutral-900 mb-4" data-aos="fade-up">{t("legal.title")}</h1>
      <p class="text-sm text-neutral-500 mb-12" data-aos="fade-up"><strong>{t("legal.lastUpdated")} :</strong> 19 juin 2026</p>

      <div class="prose prose-neutral max-w-none space-y-10" data-aos="fade-up">
        <!-- 1. Édition du site -->
        <div>
          <h2 class="text-2xl font-bold text-neutral-900 mb-4">1. {t("legal.section.1.title")}</h2>
          <p>{t("legal.section.1.text")}</p>
          <ul class="list-none ml-0 mt-2 space-y-1">
            <li><strong>Email :</strong> besmainfoenergy@gmail.com</li>
            <li><strong>{t("legal.section.1.phoneLabel")} :</strong> +213 (0) 663 62 20 10 / +213 (0) 559 32 82 04</li>
            <li><strong>{t("legal.section.1.publisherLabel")} :</strong> {t("legal.section.1.publisher")}</li>
          </ul>
          <p class="mt-2">{t("legal.section.1.law")}</p>
        </div>

        <!-- 2. Hébergement -->
        <div>
          <h2 class="text-2xl font-bold text-neutral-900 mb-4">2. {t("legal.section.2.title")}</h2>
          <p>{t("legal.section.2.text")}</p>
          <ul class="list-none ml-0 mt-2 space-y-1">
            <li><strong>Vercel Inc.</strong></li>
            <li>340 S Lemon Ave #4133, Walnut, CA 91789, USA</li>
            <li><strong>Site web :</strong> <a href="https://vercel.com" class="text-primary-600 hover:underline">vercel.com</a></li>
          </ul>
          <p class="mt-2">{t("legal.section.2.law")}</p>
        </div>

        <!-- 3. Propriété intellectuelle -->
        <div>
          <h2 class="text-2xl font-bold text-neutral-900 mb-4">3. {t("legal.section.3.title")}</h2>
          <p>{t("legal.section.3.text")}</p>
          <p class="mt-2">{t("legal.section.3.law")}</p>
        </div>

        <!-- 4. Protection des données personnelles -->
        <div>
          <h2 class="text-2xl font-bold text-neutral-900 mb-4">4. {t("legal.section.4.title")}</h2>
          <p>{t("legal.section.4.intro")}</p>
          <ul class="list-disc ml-6 mt-2 space-y-1">
            <li>{t("legal.section.4.item1")}</li>
            <li>{t("legal.section.4.item2")}</li>
            <li>{t("legal.section.4.item3")}</li>
          </ul>
        </div>

        <!-- 5. Cookies -->
        <div>
          <h2 class="text-2xl font-bold text-neutral-900 mb-4">5. {t("legal.section.5.title")}</h2>
          <p>{t("legal.section.5.text")}</p>
          <ul class="list-disc ml-6 mt-2 space-y-1">
            <li>{t("legal.section.5.item1")}</li>
            <li>{t("legal.section.5.item2")}</li>
          </ul>
          <p class="mt-2">{t("legal.section.5.ref")}</p>
        </div>

        <!-- 6. Responsabilité -->
        <div>
          <h2 class="text-2xl font-bold text-neutral-900 mb-4">6. {t("legal.section.6.title")}</h2>
          <p>{t("legal.section.6.text")}</p>
          <ul class="list-disc ml-6 mt-2 space-y-1">
            <li>{t("legal.section.6.item1")}</li>
            <li>{t("legal.section.6.item2")}</li>
            <li>{t("legal.section.6.item3")}</li>
          </ul>
          <p class="mt-2">{t("legal.section.6.disclaimer")}</p>
        </div>

        <!-- 7. Modification des mentions légales -->
        <div>
          <h2 class="text-2xl font-bold text-neutral-900 mb-4">7. {t("legal.section.7.title")}</h2>
          <p>{t("legal.section.7.text")}</p>
        </div>

        <!-- 8. Droit applicable -->
        <div>
          <h2 class="text-2xl font-bold text-neutral-900 mb-4">8. {t("legal.section.8.title")}</h2>
          <p>{t("legal.section.8.text")}</p>
        </div>

        <!-- 9. Contact -->
        <div>
          <h2 class="text-2xl font-bold text-neutral-900 mb-4">9. {t("legal.section.9.title")}</h2>
          <p>{t("legal.section.9.text")}</p>
          <ul class="list-none ml-0 mt-2 space-y-1">
            <li><strong>Email :</strong> besmainfoenergy@gmail.com</li>
            <li><strong>{t("legal.section.1.phoneLabel")} :</strong> +213 (0) 663 62 20 10 / +213 (0) 559 32 82 04</li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getLangFromUrl, useTranslations, useTranslatedPath } from "../../i18n/utils";
import projects from "../../data/projects.json";

export async function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.id },
  }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const { slug } = Astro.params;
const project = projects.find((p) => p.id === slug);
const content = project ? project[lang] || project.fr : null;
---

{project && content ? (
  <BaseLayout
    title={content.title}
    description={content.description}
    lang={lang}
    dir={lang === "ar" ? "rtl" : "ltr"}
  >
    <section class="py-20 md:py-28">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <a href={translatePath("portfolio")} class="inline-flex items-center gap-2 text-primary-600 hover:text-primary-700 font-medium mb-8">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={lang === "ar" ? "M9 5l7 7-7 7" : "M15 19l-7-7 7-7"} /></svg>
          {t("portfolio.back")}
        </a>
        <div data-aos="fade-up">
          <div class="aspect-video rounded-2xl bg-gradient-to-br from-primary-100 to-secondary-100 mb-8 flex items-center justify-center overflow-hidden">
            {project.image ? (
              <img src={project.image} alt={content.title} class="w-full h-full object-cover" />
            ) : (
              <svg class="w-24 h-24 text-primary-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            )}
          </div>
          <div class="flex items-center gap-2 mb-4">
            <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${project.category === "it" ? "bg-primary-50 text-primary-700" : "bg-secondary-50 text-secondary-700"}`}>
              {project.category === "it" ? "Informatique" : "Énergie"}
            </span>
          </div>
          <h1 class="text-3xl md:text-4xl font-bold text-neutral-900 mb-4">{content.title}</h1>
          <p class="text-lg text-neutral-600 mb-6">{content.description}</p>
          <div class="flex flex-wrap gap-2 mb-6">
            {project.tags?.map((tag) => (
              <span class="text-sm bg-neutral-100 text-neutral-600 px-3 py-1.5 rounded-lg">{tag}</span>
            ))}
          </div>
          <p class="text-neutral-500 mb-8">
            <span class="font-semibold">{t("portfolio.tech")} :</span> {content.tech}
          </p>
          {project.link && (
            <a href={project.link} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-primary-600 text-white px-6 py-3 rounded-xl font-semibold hover:bg-primary-700 transition-colors">
              {t("portfolio.view")}
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
            </a>
          )}
        </div>
      </div>
    </section>
  </BaseLayout>
) : (
  <BaseLayout title="Projet non trouvé" description="" lang={lang}>
    <section class="py-20 text-center">
      <h1 class="text-4xl font-bold text-neutral-900">Projet non trouvé</h1>
      <a href="/realisations" class="text-primary-600 mt-4 inline-block">{t("portfolio.back")}</a>
    </section>
  </BaseLayout>
)}

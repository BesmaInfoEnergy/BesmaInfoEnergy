---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout
  title={t("privacy.title")}
  description={t("privacy.desc")}
  lang={lang}
  dir={lang === "ar" ? "rtl" : "ltr"}
>
  <section class="py-20 md:py-28">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-bold text-neutral-900 mb-8" data-aos="fade-up">{t("privacy.title")}</h1>
      <div class="prose prose-neutral max-w-none" data-aos="fade-up">
        <h2>1. Collecte des données</h2>
        <p>
          Les données personnelles collectées via le formulaire de contact (nom, email, téléphone)
          sont utilisées uniquement pour répondre à votre demande. Elles ne sont jamais vendues ou
          partagées avec des tiers.
        </p>

        <h2>2. Formulaire de contact</h2>
        <p>
          Les informations envoyées via le formulaire sont transmises par email via le service
          Formspree et ne sont pas stockées sur ce site.
        </p>

        <h2>3. Cookies</h2>
        <p>
          Ce site n'utilise pas de cookies de suivi. Aucun analytics n'est installé.
        </p>

        <h2>4. Vos droits</h2>
        <p>
          Conformément à la réglementation algérienne sur la protection des données et au RGPD
          (pour les visiteurs européens), vous disposez d'un droit d'accès, de rectification et
          de suppression de vos données. Pour l'exercer, contactez-moi par email.
        </p>

        <h2>5. Sécurité</h2>
        <p>
          Ce site est en HTTPS. Les données transmises via le formulaire sont chiffrées lors de
          la transmission.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
